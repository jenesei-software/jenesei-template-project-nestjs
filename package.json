{
  "name": "nest-template",
  "version": "2.0.0",
  "description": "Production-ready NestJS starter template with TypeScript, Swagger, Docker, CI/CD, and best practices. Includes authentication, database setup, config management, and testing utilities.",
  "author": "Tazdinger",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "bin": {
    "app": "./dist/cli.js"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env NODE_ENV=development nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "start:cli": "cross-env NODE_ENV=development nest start --entryFile cli --",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "nest-commander": "^3.20.1",
    "nestjs-zod": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-themes": "^1.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/node": "^24.13.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1"
  }
}
